{% extends 'layouts/page.njk' %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

{% block content %}
  {{ super() }}

  {{ appHeading({
    text: heading
  }) }}

  {% if apiError %}
    {{ govukNotificationBanner({
      html: '<p class="govuk-body">Unable to connect to the backend API.</p>'
    }) }}
  {% endif %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-one-half">
      <h2 class="govuk-heading-m">Dead letter queue</h2>
      {% if stats.deadLetterQueue %}
        {{ govukSummaryList({
          rows: [
            {
              key: { text: "Messages" },
              value: { text: stats.deadLetterQueue.approximateMessageCount }
            },
            {
              key: { text: "Not visible" },
              value: { text: stats.deadLetterQueue.approximateMessagesNotVisible }
            },
            {
              key: { text: "Delayed" },
              value: { text: stats.deadLetterQueue.approximateMessagesDelayed }
            }
          ]
        }) }}
      {% else %}
        <p class="govuk-body">Data unavailable</p>
      {% endif %}

      <div class="govuk-button-group">
        {{ govukButton({
          text: "Peek messages",
          href: "/queues/dead-letter/peek",
          classes: "govuk-button--secondary"
        }) }}

        <form method="post" action="/queues/dead-letter/redrive" class="app-inline-form">
          <input type="hidden" name="crumb" value="{{ crumb }}" />
          <input type="hidden" name="maxMessages" value="10" />
          {{ govukButton({
            text: "Redrive (up to 10)",
            classes: "govuk-button--secondary"
          }) }}
        </form>

        {{ govukButton({
          text: "Purge all",
          href: "/queues/dead-letter/purge",
          classes: "govuk-button--warning"
        }) }}
      </div>
    </div>

    <div class="govuk-grid-column-one-half">
      <h2 class="govuk-heading-m">Main queue</h2>
      {% if stats.mainQueue %}
        {{ govukSummaryList({
          rows: [
            {
              key: { text: "Messages" },
              value: { text: stats.mainQueue.approximateMessageCount }
            }
          ]
        }) }}
      {% else %}
        <p class="govuk-body">Data unavailable</p>
      {% endif %}
    </div>
  </div>
{% endblock %}
