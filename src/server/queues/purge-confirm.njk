{% extends 'layouts/page.njk' %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/warning-text/macro.njk" import govukWarningText %}

{% block content %}
  {{ super() }}

  {{ appHeading({
    text: heading
  }) }}

  {{ govukWarningText({
    text: "This will permanently delete all messages from the dead letter queue. This action cannot be undone.",
    iconFallbackText: "Warning"
  }) }}

  <form method="post" action="/queues/dead-letter/purge">
    <input type="hidden" name="crumb" value="{{ crumb }}" />

    <div class="govuk-button-group">
      {{ govukButton({
        text: "Yes, purge all messages",
        classes: "govuk-button--warning"
      }) }}

      <a class="govuk-link" href="/queues">Cancel</a>
    </div>
  </form>
{% endblock %}
